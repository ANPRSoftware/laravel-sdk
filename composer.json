{
    "name": "anpr/laravel-sdk",
    "description": "Laravel SDK for ANPR.Software — UAE license plate detection API",
    "keywords": ["laravel", "anpr", "license-plate", "uae", "ocr", "detection"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Anpr\\LaravelSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Anpr\\LaravelSdk\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Anpr\\LaravelSdk\\AnprServiceProvider"
            ],
            "aliases": {
                "Anpr": "Anpr\\LaravelSdk\\Facades\\Anpr"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
